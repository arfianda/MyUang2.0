<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:paddingTop="42dp"
        android:paddingBottom="32dp">

        <FrameLayout
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_nav_active"
            android:elevation="4dp">
            <ImageView
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_wallet"
                android:tint="@android:color/white" />
        </FrameLayout>

        <TextView
            style="@style/TextDisplay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="MyUang"
            android:textColor="@color/primary" />

        <TextView
            style="@style/TextHeadline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="@string/login_title" />

        <TextView
            style="@style/TextBody"
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/login_desc" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_input"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="14dp"
            android:paddingRight="14dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_mail"
                android:tint="@color/on_surface_variant" />
            <EditText
                android:id="@+id/inputLoginEmail"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="10dp"
                android:layout_weight="1"
                android:background="@null"
                android:hint="contoh@email.com"
                android:inputType="textEmailAddress"
                android:singleLine="true"
                android:textColor="@color/on_surface"
                android:textColorHint="@color/on_surface_variant"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_input"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="14dp"
            android:paddingRight="8dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_lock"
                android:tint="@color/on_surface_variant" />
            <EditText
                android:id="@+id/inputLoginPassword"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="10dp"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Kata sandi"
                android:inputType="textPassword"
                android:singleLine="true"
                android:textColor="@color/on_surface"
                android:textColorHint="@color/on_surface_variant"
                android:textSize="15sp" />
            <ImageButton
                android:id="@+id/btnToggleLoginPassword"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@color/transparent"
                android:src="@drawable/ic_visibility"
                android:tint="@color/on_surface_variant" />
        </LinearLayout>

        <TextView
            android:id="@+id/linkForgotPassword"
            style="@style/TextBody"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="right"
            android:layout_marginTop="10dp"
            android:text="@string/forgot_password"
            android:textColor="@color/primary" />

        <Button
            android:id="@+id/btnLogin"
            style="@style/ButtonPrimary"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="18dp"
            android:text="@string/login_action" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">
            <Button
                android:id="@+id/btnLanguage"
                style="@style/ButtonSecondary"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginRight="6dp"
                android:layout_weight="1"
                android:text="@string/language" />
            <Button
                android:id="@+id/btnPhoneLogin"
                style="@style/ButtonSecondary"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginLeft="6dp"
                android:layout_weight="1"
                android:text="@string/phone_number" />
        </LinearLayout>

        <TextView
            android:id="@+id/linkRegister"
            style="@style/TextBody"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/register_link"
            android:textColor="@color/primary" />
    </LinearLayout>
</ScrollView>
