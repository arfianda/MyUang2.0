<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="76dp"
    android:layout_marginLeft="20dp"
    android:layout_marginRight="20dp"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_bottom_nav"
    android:elevation="8dp"
    android:gravity="center"
    android:orientation="horizontal"
    android:paddingLeft="8dp"
    android:paddingRight="8dp">

    <LinearLayout
        android:id="@+id/navDashboard"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_weight="1"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView
            android:id="@+id/navDashboardIcon"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:padding="8dp"
            android:src="@drawable/ic_wallet"
            android:tint="@color/on_surface_variant" />
        <TextView
            android:id="@+id/navDashboardLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_home"
            android:textSize="11sp"
            android:textColor="@color/on_surface_variant" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navAnalytics"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_weight="1"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView
            android:id="@+id/navAnalyticsIcon"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:padding="8dp"
            android:src="@drawable/ic_chart"
            android:tint="@color/on_surface_variant" />
        <TextView
            android:id="@+id/navAnalyticsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_analytics"
            android:textSize="11sp"
            android:textColor="@color/on_surface_variant" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navAdd"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_weight="1"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView
            android:id="@+id/navAddIcon"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:padding="8dp"
            android:src="@drawable/ic_add"
            android:tint="@color/primary" />
        <TextView
            android:id="@+id/navAddLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_add"
            android:textSize="11sp"
            android:textColor="@color/primary" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navTips"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_weight="1"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView
            android:id="@+id/navTipsIcon"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:padding="8dp"
            android:src="@drawable/ic_tips"
            android:tint="@color/on_surface_variant" />
        <TextView
            android:id="@+id/navTipsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_tips"
            android:textSize="11sp"
            android:textColor="@color/on_surface_variant" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navProfile"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_weight="1"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView
            android:id="@+id/navProfileIcon"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:padding="8dp"
            android:src="@drawable/ic_profile"
            android:tint="@color/on_surface_variant" />
        <TextView
            android:id="@+id/navProfileLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_profile"
            android:textSize="11sp"
            android:textColor="@color/on_surface_variant" />
    </LinearLayout>
</LinearLayout>
