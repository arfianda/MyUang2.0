<resources>
    <style name="Theme.MyUang" parent="@android:style/Theme.Material.Light.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowBackground">@color/surface</item>
        <item name="android:colorAccent">@color/primary</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:statusBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="TextDisplay">
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans</item>
    </style>

    <style name="TextHeadline">
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans</item>
    </style>

    <style name="TextTitle">
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans</item>
    </style>

    <style name="TextBody">
        <item name="android:textColor">@color/on_surface_variant</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">2dp</item>
        <item name="android:fontFamily">sans</item>
    </style>

    <style name="TextLabel">
        <item name="android:textColor">@color/on_surface_variant</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans</item>
    </style>

    <style name="TextNumber">
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans</item>
    </style>

    <style name="ButtonPrimary" parent="@android:style/Widget.Material.Button">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:fontFamily">sans</item>
    </style>

    <style name="ButtonSecondary" parent="@android:style/Widget.Material.Button">
        <item name="android:background">@drawable/bg_button_secondary</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:fontFamily">sans</item>
    </style>

    <style name="InputField">
        <item name="android:background">@drawable/bg_input</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textColorHint">@color/on_surface_variant</item>
        <item name="android:textSize">15sp</item>
        <item name="android:paddingLeft">16dp</item>
        <item name="android:paddingRight">16dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:fontFamily">sans</item>
    </style>
</resources>
